ENVIRONMENT=dev
VERSION=1.0.0
REQUEST_LOGGING=false

PG_HOST=localhost
PG_USER=postgres
PG_PASS=postgres
PG_DB=postgres

# Ports and URLs are derived from .env.worktree at the repo root.
# API_PORT, PG_PORT, WEB_PORT are read from environment (set by with-worktree-env.sh or .env.worktree).
# BASE_SERVICE_URL, CORS_ORIGINS, TRUSTED_ORIGINS are computed from ports if not set.
#
# To override explicitly:
# PORT=8080
# BASE_SERVICE_URL="http://localhost:8080"
# CORS_ORIGINS=http://localhost:4000
# TRUSTED_ORIGINS=http://localhost:4000,mobile://
